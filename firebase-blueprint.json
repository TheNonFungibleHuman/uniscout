{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Applicant profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "targetMajor": { "type": "string" },
        "gpa": { "type": "number" },
        "testScores": { "type": "string" },
        "extracurriculars": { "type": "string" },
        "savedSchools": { "type": "array", "items": { "type": "object" } },
        "discardedSchools": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["applicant", "mentor", "university"] }
      },
      "required": ["id", "email", "role"]
    },
    "MentorProfile": {
      "title": "MentorProfile",
      "description": "Mentor profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "university": { "type": "string" },
        "major": { "type": "string" },
        "graduationYear": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["applicant", "mentor", "university"] }
      },
      "required": ["id", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles (applicants and mentors)"
    }
  }
}
